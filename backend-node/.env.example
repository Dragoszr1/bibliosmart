NODE_ENV=development
PORT=8080

# Frontend origin for CORS (use your Vite dev server URL)
WEB_ORIGIN=http://localhost:5173

# PostgreSQL connection string (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/animepulse?schema=public

# JWT secrets (generate long random strings)
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me

# Cookie settings
COOKIE_DOMAIN=localhost

