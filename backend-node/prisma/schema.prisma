generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  watchHistory WatchProgress[]
  favorites    Favorite[]
}

model WatchProgress {
  id        String   @id @default(cuid())
  userId    String
  tmdbId    String
  mediaType MediaType
  season    Int?
  episode   Int?
  timestamp Float    @default(0) // seconds
  progress  Float    @default(0) // percent 0-100
  duration  Float?   // seconds
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@unique([userId, tmdbId, mediaType, season, episode])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  tmdbId    String
  mediaType MediaType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tmdbId, mediaType])
}

enum MediaType {
  movie
  tv
}

